{
  "name": "@effect-template/lib",
  "version": "1.0.15",
  "description": "Reusable OpenClaw panel backend library",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build --ssr src/index.ts && tsc -p tsconfig.build.json",
    "dev": "vite build --watch --ssr src/index.ts",
    "lint": "npx @ton-ai-core/vibecode-linter src/",
    "lint:tests": "npx @ton-ai-core/vibecode-linter tests/",
    "lint:effect": "npx eslint --config eslint.effect-ts-check.config.mjs .",
    "check": "tsc --noEmit",
    "test": "npx @ton-ai-core/vibecode-linter tests/ && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "effect": "^3.19.17",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "0.73.1",
    "@effect/vitest": "^0.27.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@eslint/compat": "2.0.2",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "10.0.1",
    "@prover-coder-ai/eslint-plugin-suggest-members": "^0.0.25",
    "@ton-ai-core/vibecode-linter": "^1.0.11",
    "@types/node": "^24.10.13",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-codegen": "0.34.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.3.0",
    "jscpd": "^4.0.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
